<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>David Lakubu — Blog</title>
  <link rel="stylesheet" href="assets/new_style.css" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400..900;1,6..96,400..900&family=Questrial&family=Readex+Pro:wght@200..400&display=swap"
    rel="stylesheet"
  />

  <!-- Alpine.js -->
  <script
    defer
    src="https://cdn.jsdelivr.net/npm/alpinejs@3.15.4/dist/cdn.min.js"
  ></script>

  <!-- marked.js -->
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

  <script src="assets/js/data.js"></script>
  <script src="assets/app-alpine.js"></script>
  <script src="assets/js/posts.js"></script>
</head>

<body x-data="combinedInit()" :class="themeClass">

  <!-- Masthead -->
  <header class="masthead">
    <div class="masthead-left">
      <a href="index.html" style="color: var(--ink); text-decoration: none;">← Back to Home</a>
    </div>
    <div class="masthead-center" x-text="data ? data.tagline.en : 'Blog'"></div>
    <div class="masthead-right">
      <div class="selectors">
        <div class="custom-select" x-data="themeSelector()" @click.outside="open = false">
          <div class="select-selected" :class="{ 'select-arrow-active': open }" @click="open = !open" tabindex="0">
            <span x-text="currentTheme"></span>
          </div>
          <div class="select-items" :class="{ 'select-show': open }">
            <template x-for="themeName in themes" :key="themeName">
              <div :class="{ 'same-as-selected': currentTheme === themeName }" @click="setCurrentTheme(themeName)" x-text="themeName"></div>
            </template>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Color Bar -->
  <div class="color-bar">
    <div class="cb1"></div>
    <div class="cb2"></div>
    <div class="cb3"></div>
    <div class="cb4"></div>
  </div>

  <!-- Scroll Indicator & Scroll Up Button -->
  <div class="scroll-indicator" x-data="scrollIndicator()" x-show="showIndicator" @scroll.window="handleScroll()">
    <div class="scroll-track" @click="scrollToTop()">
      <div class="scroll-progress" :style="'height: ' + scrollProgress + '%'"></div>
      <div class="scroll-thumb" :style="'top: ' + scrollProgress + '%'">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
          <path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- Blog Content -->
  <main class="blog-main">

    <!-- Blog List / Post View -->
    <section id="blog" x-data="blogSection()">
      <template x-if="loading">
        <p x-text="i18n.t('loading')">Loading...</p>
      </template>

      <template x-if="!loading && !currentPostId">
        <div class="blog-list-container">
          <div class="article-label">Writing</div>
          <h1 class="blog-list-title">Blog Articles</h1>
          <div id="blogs-list">
            <template x-for="article in articles" :key="article.id">
              <div class="work-entry">
                <div class="work-title">
                  <a :href="'posts?blog_post=' + article.id" style="color: var(--ink); text-decoration: none;" x-text="article.title"></a>
                </div>
                <div class="work-meta" x-text="formatDate(article.date)"></div>
                <div class="work-desc" x-text="article.description"></div>
              </div>
            </template>
            <p x-show="articles.length === 0" x-text="i18n.t('noArticles')">No articles found.</p>
          </div>
        </div>
      </template>

      <template x-if="!loading && currentPostId">
        <div class="blog-post-container">
          <a href="posts.html" class="back-to-list">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M19 12H5M12 19l-7-7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span x-text="i18n.t('backToList')">Back to list</span>
          </a>
          <template x-if="postMetadata">
            <div class="post-header">
              <h1 x-text="postMetadata.title"></h1>
              <p class="post-date" x-text="formatDate(postMetadata.date)"></p>
            </div>
          </template>
          <div class="post-layout">
            <aside class="toc-sidebar" x-show="tocHeadings.length > 0">
              <div class="toc-back-button">
                <a href="posts.html" class="back-button-sidebar">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path d="M19 12H5M12 19l-7-7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>Back</span>
                </a>
              </div>
          <div class="toc-title">Contents</div>
              <nav class="toc-nav">
                <template x-for="(heading, index) in tocHeadings" :key="index">
                  <a :href="'#' + heading.id" class="toc-link" :class="'toc-level-' + heading.level" :style="'padding-left: ' + ((heading.level - 1) * 12) + 'px'" x-text="heading.text" @click="scrollToHeading($event, heading.id)"></a>
                </template>
              </nav>
            </aside>
            <article class="blog-post" x-html="renderedContent"></article>
          </div>
        </div>
      </template>
    </section>
  </main>

  <footer>
    <div class="f-brand">David Lakubu</div>
    <div class="f-links">
      <a href="https://github.com/davidlakubu" target="_blank">GitHub</a>
      <a href="https://linkedin.com/in/david-lakubu" target="_blank">LinkedIn</a>
      <a href="mailto:hello@lakubudavid.me">Email</a>
    </div>
    <div class="f-right">© 2026 · MAURITIUS</div>
  </footer>

</body>
</html>
